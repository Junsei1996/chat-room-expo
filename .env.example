# Mobile app environment variables.
# Copy this file to `.env` (or `.env.local`) and fill in your values.
# Variables prefixed with EXPO_PUBLIC_ are inlined into the app at build time.

# Base URL of the deployed backend (Express + Socket.IO).
# Leave unset during local development to fall back to the LAN IP in services/api.ts.
# For production / Play Store builds this MUST point at your hosted backend, e.g.:
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com
EXPO_PUBLIC_API_URL=
