datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  messages  Message[]
  rooms     RoomMember[]
  createdAt DateTime  @default(now())
}

model Room {
  id          String       @id @default(cuid())
  name        String
  description String
  category    String
  privacy     String
  code        String       @unique
  members     Int          @default(1)
  online      Int          @default(0)
  lastMessage String?
  lastActive  String?
  messages    Message[]
  membersList RoomMember[]
  createdAt   DateTime     @default(now())
}

model RoomMember {
  id       String   @id @default(cuid())
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  room     Room     @relation(fields: [roomId], references: [id])
  roomId   String
  joinedAt DateTime @default(now())

  @@unique([userId, roomId])
}

model Message {
  id        String   @id @default(cuid())
  text      String?
  image     String?
  room      Room     @relation(fields: [roomId], references: [id])
  roomId    String
  sender    User     @relation(fields: [senderId], references: [id])
  senderId  String
  createdAt DateTime @default(now())
}
